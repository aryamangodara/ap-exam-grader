# Pick ONE auth method.

# --- Option A (recommended): AI Studio API key ---
# Free, fastest setup. Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Option B: Vertex AI service account (advanced) ---
# Path to a service-account JSON file ON DISK. Do NOT commit that file to git.
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/your-service-account.json
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global   # Gemini 3.x requires "global"; regional endpoints 404
